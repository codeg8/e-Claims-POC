        {
          "name": "Review",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// 1. Existing logic for Decision and Note\r",
                  "const decisions = ['APPROVED', 'REJECTED'];\r",
                  "const randomDecision = decisions[Math.floor(Math.random() * decisions.length)];\r",
                  "const lastClaimAmt = Number(pm.variables.get(\"lastClaimAmt\"));\r",
                  "\r",
                  "let note = (randomDecision === 'APPROVED') \r",
                  "    ? `Claim verified. ${pm.variables.replaceIn('{{$randomCatchPhrase}}')}. Approved.`\r",
                  "    : `Rejected. Reference: ${pm.variables.replaceIn('{{$randomAlphaNumeric}}')}`;\r",
                  "\r",
                  "// 2. Build the Payload Object\r",
                  "let payload = {\r",
                  "    decision: randomDecision,\r",
                  "    notes: note\r",
                  "};\r",
                  "\r",
                  "// 3. Add settlementRecommendation ONLY if conditions are met\r",
                  "// Here, we add a 50% random chance to make it \"optional\"\r",
                  "const shouldInclude = Math.random() < 0.5; \r",
                  "\r",
                  "if (randomDecision === 'APPROVED' && lastClaimAmt && shouldInclude) {\r",
                  "    payload.settlementRecommendation = Math.floor(Math.random() * (lastClaimAmt + 1));\r",
                  "}\r",
                  "\r",
                  "// 4. Save the entire object as a string variable\r",
                  "pm.variables.set(\"requestBody\", JSON.stringify(payload));\r",
                  "\r",
                  "// Optional Variable if we want to set individual feilds in request body.\r",
                  "pm.variables.set(\"randomDecision\", randomDecision);\r",
                  "pm.variables.set(\"randomNote\", note);\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
