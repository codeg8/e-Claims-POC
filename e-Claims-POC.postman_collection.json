      "item": [
        {
          "name": "List Claim",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {\r",
                  "    const responseData = pm.response.json();\r",
                  "    console.log(\"Full Response Body:\", responseData);\r",
                  "\r",
                  "    let foundId = null;\r",
                  "    let amt = null;\r",
                  "\r",
                  "    // Logic for Raw Array: [ {...}, {...} ]\r",
                  "    if (Array.isArray(responseData) && responseData.length > 0) {\r",
                  "        foundId = responseData[0].claimId || responseData[0].id;\r",
                  "        amt = responseData[0].amount;\r",
                  "    } \r",
                  "    // Logic for Wrapped Array: { \"claims\": [...] }\r",
                  "    else if (responseData.claims && Array.isArray(responseData.claims) && responseData.claims.length > 0) {\r",
                  "        foundId = responseData.claims[0].claimId || responseData.claims[0].id;\r",
                  "        amt = responseData.claims[0].amount;\r",
                  "    }\r",
                  "    // Logic for Single Object: { \"claimId\": \"...\" }\r",
                  "    else if (responseData.claimId || responseData.id) {\r",
                  "        foundId = responseData.claimId || responseData.id;\r",
                  "        amt = responseData.amount;\r",
                  "    }\r",
                  "\r",
                  "    if (foundId) {\r",
                  "        pm.collectionVariables.set(\"lastClaimId\", foundId);\r",
                  "        pm.collectionVariables.set(\"lastClaimAmt\", parseFloat(amt));\r",
                  "        console.log(\"✅ SUCCESS: lastClaimId set to:\", foundId);\r",
                  "    } else {\r",
                  "        console.error(\"❌ FAILURE: Could not find an ID. Check key names (claimId vs id)\");\r",
                  "    }\r",
                  "} catch (e) {\r",
                  "    console.error(\"❌ ERROR: Response was not valid JSON\", e);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
